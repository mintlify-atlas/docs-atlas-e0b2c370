  "keyFeatures": [
    "Citation anchoring — every generated line of code references the exact paper section and equation it implements",
    "Ambiguity auditing — classifies every implementation detail as SPECIFIED, PARTIALLY_SPECIFIED, or UNSPECIFIED before writing code",
    "UNSPECIFIED flag system — honest flagging of every implementation gap with common alternatives listed",
    "Appendix mining — treats appendices, footnotes, and figure captions as first-class specification sources",
    "Official code integration — searches for and cross-references authors' official repositories",
    "Multi-mode generation — minimal, full, and educational modes for different use cases",
    "Framework support — generates PyTorch (default), JAX, or NumPy implementations",
    "5-stage pipeline — paper acquisition, contribution identification, ambiguity audit, code generation, walkthrough notebook"
  ],
  "publicApiSurface": [
    "/paper2code <arxiv_url_or_id>",
    "/paper2code <arxiv_id> --framework jax",
    "/paper2code <arxiv_id> --mode full",
    "/paper2code <arxiv_id> --mode educational",
